        <mxCell id="U38sufAfSzDMHU5akTwv-31" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;p style=&quot;line-height: 20px;&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Rules&lt;br&gt;&lt;/font&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;DMZ → Internal:&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;DENY&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;all&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;ALLOW&lt;/font&gt;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;&lt;div style=&quot;line-height: 20px;&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Source: Web Servers (DMZ subnet only)&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;/li&gt;&lt;li&gt;&lt;div style=&quot;line-height: 20px;&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Destination: DB cluster FQDN/IP&lt;/font&gt;&lt;/div&gt;&lt;/li&gt;&lt;li&gt;&lt;div style=&quot;line-height: 20px;&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Port: 1433&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;/li&gt;&lt;li&gt;&lt;div style=&quot;line-height: 20px;&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;------------------------------------------&lt;/font&gt;&lt;/div&gt;&lt;/li&gt;&lt;li&gt;&lt;div style=&quot;line-height: 20px;&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Source: Web Servers&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;/li&gt;&lt;li&gt;&lt;div style=&quot;line-height: 20px;&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Destination:&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-family: &amp;quot;Lucida Console&amp;quot;; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Redis&lt;/span&gt;&lt;/div&gt;&lt;/li&gt;&lt;li&gt;&lt;div style=&quot;line-height: 20px;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Lucida Console&amp;quot;; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Port: 6379&lt;/span&gt;&lt;/div&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/ul&gt;&lt;li&gt;&lt;font style=&quot;&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;VPN → Internal:&amp;nbsp;&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;DENY:&lt;/font&gt;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;all&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Database (TCP 1433)&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;ALLOW:&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;AD / Identity services:&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;DNS: TCP/UDP 53&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Kerberos: TCP/UDP 88&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;LDAPS: TCP 636&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Global Catalog (LDAPS): TCP 3269&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;File Server (SMB) TCP 445&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/ul&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;To access Web server from internal network users have to visit public IP, same as external users&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;VPN access is limited to the File server&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Database server which web servers use is internal network, that communication is allowed by port 1433&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Segoe UI&amp;quot;; font-size: 14px; line-height: 20px;&quot;&gt;Database access from internal network is restricted to authorized administrative systems only and specific users&lt;/div&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Web server authentication is local, stateless&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;code style=&quot;&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Web servers have no access to internal services except the database over TCP 1433&lt;/font&gt;&lt;/code&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;When accessing file server, users should authenticate with domain username and password&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Workstations access DB locally, over private FQDN/private IP&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;VPN users should have no access to the database&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Redis is deployed on a dedicated VM using containerization, configured in a clustered/replicated mode with persistent storage for high availability and resilience&lt;/font&gt;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Restrict source IP → only web servers&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Enable authentication / password&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;div style=&quot;line-height: 20px;&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Session store&lt;/font&gt;&lt;/div&gt;&lt;/li&gt;&lt;li&gt;&lt;div style=&quot;line-height: 20px;&quot;&gt;&lt;div style=&quot;line-height: 20px;&quot;&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Cache&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/li&gt;&lt;/ul&gt;&lt;li&gt;&lt;font face=&quot;Lucida Console&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Segoe UI&amp;quot;; font-size: 14px; line-height: 20px;&quot;&gt;10.0.10.0/24 → Management&lt;/div&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="730" width="820" x="-400" y="360" as="geometry" />
        </mxCell>
